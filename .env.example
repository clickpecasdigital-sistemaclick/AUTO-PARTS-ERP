# =============================================================================
# AutoCore ERP — Environment Variables Reference (Sprint 14)
# Copie para .env e preencha os valores ANTES do deploy.
# NUNCA commitar .env com valores reais no repositório.
# =============================================================================

# ---- AMBIENTE ---------------------------------------------------------------
NODE_ENV=production                  # development | staging | production
APP_VERSION=1.0.0

# ---- BANCO DE DADOS (Supabase / PostgreSQL) ----------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ---- SUPABASE ---------------------------------------------------------------
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...             # Public anon key
SUPABASE_SERVICE_KEY=eyJ...          # Service role key (NUNCA expor ao frontend)
SUPABASE_JWT_SECRET=[JWT secret do projeto Supabase]

# ---- JWT --------------------------------------------------------------------
JWT_SECRET=[string aleatória >= 64 chars — use: openssl rand -hex 64]
JWT_EXPIRY=15m                       # Acesso (curto — 15 min)
REFRESH_TOKEN_EXPIRY=30d             # Refresh (longo — 30 dias)
JWT_ISSUER=autocore-erp
JWT_AUDIENCE=autocore-erp-api

# ---- SEGURANÇA ---------------------------------------------------------------
AES_256_KEY=[32 bytes exatos — use: openssl rand -hex 32 | head -c 32]
BCRYPT_ROUNDS=12

# ---- REDIS -------------------------------------------------------------------
REDIS_URL=redis://:[password]@redis:6379
REDIS_PASSWORD=[senha forte — use: openssl rand -hex 32]
REDIS_TTL_SECONDS=300                # TTL padrão de cache (5 min)

# ---- CORS -------------------------------------------------------------------
CORS_ORIGIN=https://app.autocore.example.com,https://app-staging.autocore.example.com

# ---- IP WHITELIST -----------------------------------------------------------
IP_WHITELIST=127.0.0.1,::1           # IPs nunca bloqueados pelo rate limiter

# ---- RATE LIMITING ----------------------------------------------------------
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=60

# ---- LGPD -------------------------------------------------------------------
LGPD_DPO_EMAIL=dpo@empresa.com       # Encarregado LGPD para notificações
LGPD_RETENTION_DAYS=1825             # 5 anos (padrão recomendado)

# ---- BACKUP -----------------------------------------------------------------
BACKUP_ENCRYPTION_KEY=[32 bytes — diferente da AES_256_KEY]
BACKUP_RETENTION_FULL_DAYS=90
BACKUP_RETENTION_INCREMENTAL_DAYS=30
BACKUP_SCHEDULE_FULL=0 3 * * *       # Cron: full backup às 03:00 UTC
BACKUP_SCHEDULE_INCREMENTAL=0 * * * * # Cron: incremental a cada hora
BACKUP_STORAGE_BUCKET=autocore-backups

# ---- SMTP (estrutura — integração com provedor em sprint posterior) ----------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.empresa.com
SMTP_PASS=[API key do Mailgun/SendGrid]
SMTP_FROM=no-reply@empresa.com
SMTP_FROM_NAME=AutoCore ERP

# ---- ANTHROPIC IA -----------------------------------------------------------
# Opcional — a API key é passada via header no AiAssistantService
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---- OBSERVABILIDADE --------------------------------------------------------
LOG_LEVEL=info                       # debug | info | warn | error
LOG_FORMAT=json                      # json (produção) | pretty (desenvolvimento)
SENTRY_DSN=https://...@sentry.io/... # Opcional — error tracking
OPENTELEMETRY_ENDPOINT=              # Opcional — distributed tracing

# ---- 2FA --------------------------------------------------------------------
TOTP_ISSUER=AutoCore ERP
TOTP_ALGORITHM=SHA1
TOTP_DIGITS=6
TOTP_STEP=30

# ---- DOCKER -----------------------------------------------------------------
API_PORT=3000
WEB_PORT=80

# ---- AMBIENTE DESENVOLVIMENTO (sobrescreve os valores acima em dev) ---------
# Para desenvolvimento local, crie .env.development com:
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# SUPABASE_URL=http://localhost:54321
# JWT_SECRET=dev-jwt-secret-apenas-local-nunca-producao
# AES_256_KEY=dev-aes-key-apenas-local-nunca-em-producao
