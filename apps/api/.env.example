# =============================================================================
# Auto Parts ERP — API (.env)
# Copie para .env e preencha com os dados do seu projeto Supabase
# =============================================================================

# ---- Servidor ---------------------------------------------------------------
PORT=3333
NODE_ENV=production

# ---- Banco (Supabase) -------------------------------------------------------
# Connection Pooler (porta 6543) para a API — usa PgBouncer
DATABASE_URL=postgresql://postgres.SEU-PROJECT-ID:SUA-SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Conexão direta (porta 5432) para migrations e seed
DIRECT_URL=postgresql://postgres.SEU-PROJECT-ID:SUA-SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ---- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://SEU-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=eyJ...sua-chave-anon
SUPABASE_SERVICE_KEY=eyJ...sua-service-role-key
SUPABASE_JWT_SECRET=seu-jwt-secret-do-supabase

# ---- JWT --------------------------------------------------------------------
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE-UM-SECRET-FORTE-64-CHARS-MINIMO
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# ---- Segurança --------------------------------------------------------------
# Gerar: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
AES_256_KEY=EXATAMENTE-32-CHARS-NADA-MAIS!!

# ---- CORS -------------------------------------------------------------------
# Sua URL do Netlify (ex: https://autocore-erp.netlify.app)
CORS_ORIGIN=https://SEU-APP.netlify.app,http://localhost:5173

# ---- Anthropic (IA Copilot) -------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...sua-chave

# ---- Email (opcional) -------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
SMTP_FROM=noreply@seudominio.com
