// ---- DATA WAREHOUSE — DIMENSÕES --------------------------------------------

/// Dimensão Tempo — pré-populada para range 2020-2030 (via ETL seed).
/// Evita GROUP BY com funções de data em queries analíticas — JOIN
/// direto com campos já indexados.
model DimTime {
  dateKey     Int      @id // YYYYMMDD — chave natural (ex: 20260701)
  date        DateTime @db.Date
  year        Int
  quarter     Int
  month       Int
  week        Int      // ISO week
  dayOfWeek   Int      @map("day_of_week")
  dayOfMonth  Int      @map("day_of_month")
  monthName   String   @map("month_name")
  weekdayName String   @map("weekday_name")
  isWeekend   Boolean  @map("is_weekend")
  isHoliday   Boolean  @default(false) @map("is_holiday")

  @@map("dim_time")
}

// ---- DATA WAREHOUSE — FATOS ------------------------------------------------

/// Fato Venda — granularidade: item de venda. ETL incremental via
/// `lastSyncAt` do processo ETL — apenas novos registros são processados.
model FactSale {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  dateKey         Int      @map("date_key")
  branchId        String   @map("branch_id") @db.Uuid
  saleId          String   @map("sale_id") @db.Uuid
  saleItemId      String?  @map("sale_item_id") @db.Uuid
  productId       String?  @map("product_id") @db.Uuid
  customerId      String?  @map("customer_id") @db.Uuid
  salespersonId   String?  @map("salesperson_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  brandId         String?  @map("brand_id") @db.Uuid
  quantity        Decimal  @db.Decimal(15, 4)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(15, 4)
  unitCost        Decimal  @default(0) @map("unit_cost") @db.Decimal(15, 4)
  discountAmount  Decimal  @default(0) @map("discount_amount") @db.Decimal(15, 2)
  grossRevenue    Decimal  @map("gross_revenue") @db.Decimal(15, 2)
  netRevenue      Decimal  @map("net_revenue") @db.Decimal(15, 2)
  grossProfit     Decimal  @map("gross_profit") @db.Decimal(15, 2)
  margin          Decimal  @map("margin") @db.Decimal(7, 4) // percentual
  syncedAt        DateTime @default(now()) @map("synced_at")

  @@unique([tenantId, saleItemId])
  @@index([tenantId, dateKey])
  @@index([tenantId, productId])
  @@index([tenantId, customerId])
  @@index([tenantId, branchId, dateKey])
  @@map("fact_sales")
}

/// Fato Compra — granularidade: item de pedido de compra.
model FactPurchase {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  dateKey           Int      @map("date_key")
  branchId          String   @map("branch_id") @db.Uuid
  purchaseOrderId   String   @map("purchase_order_id") @db.Uuid
  purchaseItemId    String?  @map("purchase_item_id") @db.Uuid
  productId         String?  @map("product_id") @db.Uuid
  supplierId        String?  @map("supplier_id") @db.Uuid
  categoryId        String?  @map("category_id") @db.Uuid
  quantity          Decimal  @db.Decimal(15, 4)
  unitCost          Decimal  @map("unit_cost") @db.Decimal(15, 4)
  totalCost         Decimal  @map("total_cost") @db.Decimal(15, 2)
  leadTimeDays      Int?     @map("lead_time_days")
  syncedAt          DateTime @default(now()) @map("synced_at")

  @@unique([tenantId, purchaseItemId])
  @@index([tenantId, dateKey])
  @@index([tenantId, supplierId])
  @@map("fact_purchases")
}

/// Fato Estoque — snapshot diário (granularidade: produto × armazém × dia).
model FactStock {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  dateKey       Int      @map("date_key")
  productId     String   @map("product_id") @db.Uuid
  warehouseId   String   @map("warehouse_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  quantityOnHand Decimal @map("quantity_on_hand") @db.Decimal(15, 4)
  quantityReserved Decimal @default(0) @map("quantity_reserved") @db.Decimal(15, 4)
  averageCost   Decimal  @map("average_cost") @db.Decimal(15, 4)
  totalValue    Decimal  @map("total_value") @db.Decimal(15, 2)
  syncedAt      DateTime @default(now()) @map("synced_at")

  @@unique([tenantId, dateKey, productId, warehouseId])
  @@index([tenantId, dateKey])
  @@index([tenantId, productId])
  @@map("fact_stock")
}

/// Fato Financeiro — movimentações de contas a pagar e a receber.
model FactFinancial {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  dateKey       Int      @map("date_key") // data de vencimento
  paidDateKey   Int?     @map("paid_date_key") // data de pagamento real
  type          String   // 'payable' | 'receivable'
  status        String   // 'pending' | 'paid' | 'overdue' | 'cancelled'
  amount        Decimal  @db.Decimal(15, 2)
  paidAmount    Decimal  @default(0) @map("paid_amount") @db.Decimal(15, 2)
  customerId    String?  @map("customer_id") @db.Uuid
  supplierId    String?  @map("supplier_id") @db.Uuid
  syncedAt      DateTime @default(now()) @map("synced_at")

  @@index([tenantId, dateKey])
  @@index([tenantId, type, status])
  @@map("fact_financial")
}

/// Fato Oficina — granularidade: Ordem de Serviço concluída.
model FactWorkshop {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  dateKey         Int      @map("date_key") // data de abertura
  closedDateKey   Int?     @map("closed_date_key") // data de conclusão
  serviceOrderId  String   @map("service_order_id") @db.Uuid
  mechanicId      String?  @map("mechanic_id") @db.Uuid
  customerId      String?  @map("customer_id") @db.Uuid
  vehicleId       String?  @map("vehicle_id") @db.Uuid
  laborAmount     Decimal  @default(0) @map("labor_amount") @db.Decimal(15, 2)
  partsAmount     Decimal  @default(0) @map("parts_amount") @db.Decimal(15, 2)
  totalAmount     Decimal  @default(0) @map("total_amount") @db.Decimal(15, 2)
  durationHours   Decimal? @map("duration_hours") @db.Decimal(7, 2)
  isRework        Boolean  @default(false) @map("is_rework")
  npsScore        Int?     @map("nps_score")
  syncedAt        DateTime @default(now()) @map("synced_at")

  @@unique([tenantId, serviceOrderId])
  @@index([tenantId, dateKey])
  @@index([tenantId, mechanicId])
  @@map("fact_workshop")
}

// ---- ETL -------------------------------------------------------------------

/// Controle de sincronização ETL por entidade (processamento incremental).
/// `lastSyncAt` é o cursor — apenas registros criados/atualizados após
/// esta data são processados no próximo ciclo.
model EtlSyncControl {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  entity      String    // 'sale' | 'purchase' | 'stock' | 'financial' | 'workshop'
  lastSyncAt  DateTime  @default(now()) @map("last_sync_at")
  lastStatus  String    @default("idle") @map("last_status") // 'idle' | 'running' | 'done' | 'error'
  lastError   String?   @map("last_error")
  rowsProcessed Int     @default(0) @map("rows_processed")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, entity])
  @@index([tenantId])
  @@map("etl_sync_controls")
}

// ---- ALERTAS ---------------------------------------------------------------

enum AlertSeverity {
  info
  warning
  critical
}

enum AlertStatus {
  active
  acknowledged
  resolved
  snoozed
}

/// Instância de alerta gerado pelo motor de alertas.
/// Os alertas são gerados automaticamente pelo `AlertsEngineService` com
/// base em queries nos fatos e nas tabelas operacionais — nenhuma regra
/// hardcoded, todas configuráveis via `AlertRule`.
model Alert {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  ruleId        String?       @map("rule_id") @db.Uuid
  severity      AlertSeverity
  status        AlertStatus   @default(active)
  category      String        // 'stock' | 'financial' | 'fiscal' | 'workshop' | 'sales' | 'crm'
  title         String
  message       String
  entityType    String?       @map("entity_type") // 'product' | 'customer' | 'invoice' etc.
  entityId      String?       @map("entity_id") @db.Uuid
  internalLink  String?       @map("internal_link")
  acknowledgedAt DateTime?    @map("acknowledged_at")
  acknowledgedBy String?      @map("acknowledged_by") @db.Uuid
  resolvedAt    DateTime?     @map("resolved_at")
  snoozedUntil  DateTime?     @map("snoozed_until")
  expiresAt     DateTime?     @map("expires_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  rule AlertRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, severity, status])
  @@map("alerts")
}

/// Regra parametrizável para geração de alertas (briefing: "motor de alertas").
model AlertRule {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String
  category    String
  severity    AlertSeverity @default(warning)
  isActive    Boolean       @default(true) @map("is_active")
  checkQuery  String        @map("check_query") // nome do check (resolvido em código, não SQL livre)
  params      Json          @default("{}") // parâmetros do check (ex: {"minStock": 5})
  internalLink String?      @map("internal_link")
  createdAt   DateTime      @default(now()) @map("created_at")

  alerts Alert[]

  @@index([tenantId])
  @@map("alert_rules")
}

