// ---- MARKETPLACE / PLUGINS -------------------------------------------------

enum PluginCategory {
  integration
  automation
  report
  widget
  payment
  fiscal
  crm
  communication
  utility
}

/// Plugin disponível no Marketplace.
model Plugin {
  id          String         @id @default(uuid()) @db.Uuid
  slug        String         @unique
  name        String
  description String?
  category    PluginCategory
  version     String
  author      String?
  logoUrl     String?        @map("logo_url")
  price       Decimal?       @db.Decimal(10, 2) // null = gratuito
  isPaid      Boolean        @default(false) @map("is_paid")
  isVerified  Boolean        @default(false) @map("is_verified")
  avgRating   Decimal?       @default(0) @map("avg_rating") @db.Decimal(3, 2)
  totalInstalls Int          @default(0) @map("total_installs")
  dependencies String[]      // slugs de outros plugins necessários
  requiredPlan PlanTier?     @map("required_plan") // plano mínimo necessário
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")

  installations PluginInstallation[]

  @@map("plugins")
}

/// Plugin instalado em um tenant.
model PluginInstallation {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  pluginId    String    @map("plugin_id") @db.Uuid
  version     String
  isEnabled   Boolean   @default(true) @map("is_enabled")
  config      Json?     // configurações específicas do plugin por tenant
  installedAt DateTime  @default(now()) @map("installed_at")
  installedBy String    @map("installed_by") @db.Uuid
  updatedAt   DateTime  @updatedAt @map("updated_at")

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pluginId])
  @@index([tenantId])
  @@map("plugin_installations")
}

// ---- API GATEWAY -----------------------------------------------------------

/// API Key para acesso externo (integrations, SDK, webhooks out).
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  name        String
  keyHash     String    @unique @map("key_hash") // SHA-256 — nunca armazenar a chave em plaintext
  keyPrefix   String    @map("key_prefix") // "ak_" + primeiros 8 chars para identificação
  scopes      String[]  // ex: ["read:sales", "write:products", "read:fiscal"]
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  ipWhitelist String[]  @map("ip_whitelist")
  rateLimit   Int?      @map("rate_limit") // req/min (override do plano)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([keyHash])
  @@map("api_keys")
}

// ---- WEBHOOKS --------------------------------------------------------------

/// Endpoint de webhook configurado pelo tenant.
model WebhookEndpoint {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  url         String
  events      String[]  // ex: ["sale.created", "invoice.issued", "customer.updated"]
  secret      String    // HMAC-SHA256 signing secret (criptografado AES-256)
  isActive    Boolean   @default(true) @map("is_active")
  description String?
  retryCount  Int       @default(3) @map("retry_count")
  timeoutMs   Int       @default(5000) @map("timeout_ms")
  lastPingAt  DateTime? @map("last_ping_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

/// Entrega de webhook (log de cada disparo).
model WebhookDelivery {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  endpointId      String    @map("endpoint_id") @db.Uuid
  event           String    // ex: "sale.created"
  payload         Json
  responseStatus  Int?      @map("response_status")
  responseBody    String?   @map("response_body")
  duration        Int?      // ms
  attempt         Int       @default(1)
  success         Boolean   @default(false)
  nextRetryAt     DateTime? @map("next_retry_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([tenantId, event])
  @@index([endpointId, createdAt])
  @@map("webhook_deliveries")
}

// ---- PORTAIS ---------------------------------------------------------------

enum PortalType {
  customer
  supplier
  accountant
}

/// Token de acesso a portais externos (Cliente / Fornecedor / Contador).
/// Acesso sem autenticação do ERP — JWT de curta duração emitido pelo PortalService.
model PortalToken {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  type        PortalType
  entityId    String     @map("entity_id") @db.Uuid  // customerId | supplierId | userId
  tokenHash   String     @unique @map("token_hash")
  email       String?    // para envio de link de acesso
  scopes      String[]   // quais seções o portal pode acessar
  isActive    Boolean    @default(true) @map("is_active")
  expiresAt   DateTime   @map("expires_at")
  lastAccessAt DateTime? @map("last_access_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([tenantId, type])
  @@map("portal_tokens")
}

// ---- I18N ------------------------------------------------------------------

/// Chave de tradução (multi-idioma). Suporta pt-BR, en-US, es-ES.
model I18nKey {
  id       String  @id @default(uuid()) @db.Uuid
  key      String  // ex: "common.save" | "sales.create.title"
  ptBR     String  @map("pt_br")
  enUS     String? @map("en_us")
  esES     String? @map("es_es")
  category String? // módulo/contexto
  isSystem Boolean @default(true) @map("is_system") // false = customizável por tenant

  @@unique([key])
  @@map("i18n_keys")
}

// =============================================================================
// SEÇÃO 17 — ENTERPRISE ULTIMATE + IA COPILOT + GO LIVE (Sprint 16)
// =============================================================================

// ---- IA COPILOT -------------------------------------------------------------

/// Sessão do IA Copilot — mantém o contexto da conversa por módulo/tela.
/// Permissões verificadas antes de cada ação: Copilot NUNCA executa
/// operações sem checar o role do usuário no PermissionsGuard.
model CopilotSession {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  context      Json     @default("{}") // módulo ativo, entityId, filtros
  messages     Json     @default("[]") // [{role, content, action?, result?}]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId, userId])
  @@map("copilot_sessions")
}

/// Previsão gerada pela IA Analítica (vendas, estoque, inadimplência, etc.).
/// Armazenada para exibir no dashboard e acionar automações.
model AiPrediction {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  type         String   // 'sales_forecast' | 'stock_rupture' | 'churn_risk' | 'purchase_suggestion' etc.
  entityType   String?  @map("entity_type") // 'product' | 'customer' | 'category'
  entityId     String?  @map("entity_id") @db.Uuid
  prediction   Json     // dados previstos (valor, probabilidade, horizon, etc.)
  confidence   Decimal? @db.Decimal(5, 4) // 0.0 a 1.0
  horizon      Int?     // dias de horizonte da previsão
  validUntil   DateTime @map("valid_until")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId, type])
  @@index([tenantId, entityId])
  @@map("ai_predictions")
}

// ---- WORKFLOW BUILDER (extensão do motor de automações Sprint 13) -----------

enum WorkflowStatus {
  draft
  active
  paused
  archived
}

/// Workflow visual (SE/ENTÃO/SENÃO/AGENDAR/LOOP) — extensão do motor
/// de automações da Sprint 13 com suporte a múltiplos passos encadeados.
model WorkflowDefinition {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  name        String
  description String?
  trigger     String         // 'stock_below_min' | 'overdue_payment' | 'sale_created' | 'schedule' etc.
  triggerParams Json         @default("{}") @map("trigger_params")
  status      WorkflowStatus @default(draft)
  steps       Json           // array de WorkflowStep serializado (nó, condição, ação, próximo)
  runCount    Int            @default(0) @map("run_count")
  lastRunAt   DateTime?      @map("last_run_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  createdBy   String?        @map("created_by") @db.Uuid

  executions WorkflowExecution[]

  @@index([tenantId])
  @@map("workflow_definitions")
}

/// Log de execução de um workflow.
model WorkflowExecution {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  workflowId   String    @map("workflow_id") @db.Uuid
  triggeredBy  String    @map("triggered_by") // 'scheduler' | 'event' | 'manual'
  status       String    @default("running") // 'running' | 'completed' | 'failed' | 'partial'
  stepsResult  Json?     @map("steps_result")
  error        String?
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([tenantId, workflowId])
  @@map("workflow_executions")
}

// ---- COMUNICAÇÃO (Email / WhatsApp / SMS) -----------------------------------

enum MessageChannel {
  email
  whatsapp
  sms
  push
}

enum MessageStatus {
  queued
  sent
  delivered
  failed
  bounced
}

/// Template de mensagem reutilizável (briefing: Templates HTML, WhatsApp, SMS).
/// Suporta variáveis {{nome}}, {{valor}}, {{link}} no corpo.
model MessageTemplate {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String?        @map("tenant_id") @db.Uuid // null = template global do sistema
  channel     MessageChannel
  name        String
  subject     String?        // apenas para email
  body        String         // HTML para email, texto para WhatsApp/SMS
  variables   String[]       // variáveis suportadas: ["nome", "valor", "link"]
  isSystem    Boolean        @default(false) @map("is_system")
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([tenantId, channel])
  @@map("message_templates")
}

/// Histórico de mensagens enviadas.
model MessageHistory {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  channel      MessageChannel
  templateId   String?        @map("template_id") @db.Uuid
  recipient    String         // email, telefone ou token push
  subject      String?
  body         String
  status       MessageStatus  @default(queued)
  externalId   String?        @map("external_id")
  errorMessage String?        @map("error_message")
  sentAt       DateTime?      @map("sent_at")
  deliveredAt  DateTime?      @map("delivered_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  @@index([tenantId, channel, status])
  @@map("message_history")
}

// ---- SUPORTE ---------------------------------------------------------------

enum TicketStatus {
  open
  in_progress
  waiting_customer
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  critical
}

/// Chamado de suporte interno (distinto do SupportTicket do CRM, Sprint 08).
model HelpTicket {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  subject     String
  description String
  status      TicketStatus   @default(open)
  priority    TicketPriority @default(medium)
  category    String?        // 'fiscal' | 'financial' | 'technical' | 'billing' etc.
  assignedTo  String?        @map("assigned_to") @db.Uuid
  resolvedAt  DateTime?      @map("resolved_at")
  closedAt    DateTime?      @map("closed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  messages HelpMessage[]

  @@index([tenantId, status])
  @@map("help_tickets")
}

/// Mensagem de um chamado de suporte interno (chat do HelpDesk).
model HelpMessage {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String
  isAgent   Boolean  @default(false) @map("is_agent")
  createdAt DateTime @default(now()) @map("created_at")

  ticket HelpTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("help_messages")
}

// ---- TELEMETRIA ------------------------------------------------------------

/// Evento de telemetria (uso de funcionalidades, tempo em tela, erros).
/// Coletado apenas com consentimento LGPD explícito (campo `consentGranted`
/// verificado antes de cada inserção).
model TelemetryEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  sessionId   String?  @map("session_id")
  event       String   // 'page_view' | 'feature_used' | 'error' | 'performance'
  screen      String?
  duration    Int?     // ms
  metadata    Json?
  appVersion  String?  @map("app_version")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, event])
  @@index([createdAt])
  @@map("telemetry_events")
}

// ---- SETUP WIZARD ----------------------------------------------------------

/// Progresso do assistente de implantação por tenant.
model SetupWizardProgress {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @unique @map("tenant_id") @db.Uuid
  currentStep Int      @default(0) @map("current_step")
  steps       Json     @default("{}") // {company: true, users: false, ...}
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("setup_wizard_progress")
}

// ---- IMPORTAÇÕES / EXPORTAÇÕES ---------------------------------------------

enum ImportStatus {
  pending
  processing
  done
  failed
  partial
}

/// Job de importação universal (CSV/Excel/XML/JSON — briefing).
model ImportJob {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  entity        String       // 'products' | 'customers' | 'suppliers' etc.
  source        String       // 'csv' | 'xlsx' | 'xml' | 'json' | 'bling' | 'tiny' | 'omie'
  filePath      String?      @map("file_path")
  mapping       Json?        // campo_origem → campo_destino
  status        ImportStatus @default(pending)
  totalRows     Int?         @map("total_rows")
  processedRows Int          @default(0) @map("processed_rows")
  errorRows     Int          @default(0) @map("error_rows")
  errors        Json?        // [{row, field, message}]
  startedAt     DateTime     @default(now()) @map("started_at")
  completedAt   DateTime?    @map("completed_at")

  @@index([tenantId])
  @@map("import_jobs")
}

/// Job de exportação universal.
model ExportJob {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  entity       String
  format       String       // 'csv' | 'xlsx' | 'pdf' | 'json' | 'xml' | 'zip'
  filters      Json?
  status       ImportStatus @default(pending)
  filePath     String?      @map("file_path")
  rowCount     Int?         @map("row_count")
  startedAt    DateTime     @default(now()) @map("started_at")
  completedAt  DateTime?    @map("completed_at")

  @@index([tenantId])
  @@map("export_jobs")
}
