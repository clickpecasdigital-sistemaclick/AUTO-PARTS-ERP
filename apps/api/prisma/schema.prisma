enum AutomationTrigger {
  stock_below_minimum
  customer_overdue
  certificate_expiring
  sale_above_target
  sale_below_target
  margin_below_threshold
  cash_flow_negative
  invoice_rejected
  order_delayed
}

enum AutomationAction {
  create_purchase_suggestion
  send_notification
  create_alert
  send_email
  webhook
}

enum AutomationStatus {
  active
  paused
  error
}

/// Regra de automação (briefing: "SE → ENTÃO").
model Automation {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  name        String
  description String?
  trigger     AutomationTrigger
  triggerParams Json            @default("{}") @map("trigger_params")
  action      AutomationAction
  actionParams Json             @default("{}") @map("action_params")
  status      AutomationStatus  @default(active)
  lastRunAt   DateTime?         @map("last_run_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  createdBy   String?           @map("created_by") @db.Uuid

  logs AutomationLog[]

  @@index([tenantId])
  @@index([trigger])
  @@map("automations")
}

/// Log de execução de automação.
model AutomationLog {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  automationId String    @map("automation_id") @db.Uuid
  triggeredBy  String    @map("triggered_by") // 'scheduler' | 'manual' | 'event'
  status       String    // 'success' | 'error' | 'skipped'
  result       Json?
  error        String?
  executedAt   DateTime  @default(now()) @map("executed_at")

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([tenantId, automationId])
  @@map("automation_logs")
}

