// ---- PLANOS -----------------------------------------------------------------

enum PlanTier {
  starter
  pro
  business
  enterprise
  ultimate
}

/// Plano de assinatura SaaS (briefing: Starter/Pro/Business/Enterprise/Ultimate).
/// Cada plano define limites de uso — `null` = ilimitado.
model Plan {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique // "Starter", "Pro", etc.
  tier        PlanTier
  description String?
  priceMonthly Decimal? @map("price_monthly") @db.Decimal(10, 2)
  priceYearly  Decimal? @map("price_yearly")  @db.Decimal(10, 2)
  isActive    Boolean   @default(true) @map("is_active")
  isPublic    Boolean   @default(true) @map("is_public") // false = plano negociado
  trialDays   Int       @default(14) @map("trial_days")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  limits        PlanLimits?
  subscriptions Subscription[]
  features      PlanFeature[]

  @@map("plans")
}

/// Limites de cada plano (null = ilimitado).
model PlanLimits {
  id              String  @id @default(uuid()) @db.Uuid
  planId          String  @unique @map("plan_id") @db.Uuid
  maxUsers        Int?    @map("max_users")
  maxBranches     Int?    @map("max_branches")
  maxProducts     Int?    @map("max_products")
  maxCustomers    Int?    @map("max_customers")
  maxSuppliers    Int?    @map("max_suppliers")
  maxMonthlyNfes  Int?    @map("max_monthly_nfes")
  maxMonthlyOs    Int?    @map("max_monthly_os")
  maxStorageMb    Int?    @map("max_storage_mb")
  maxAiQueryMonth Int?    @map("max_ai_query_month")
  maxApiReqDay    Int?    @map("max_api_req_day")
  maxDashboards   Int?    @map("max_dashboards")
  maxReports      Int?    @map("max_reports")
  maxPlugins      Int?    @map("max_plugins")
  maxWebhooks     Int?    @map("max_webhooks")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_limits")
}

/// Feature flag por plano (ex: "white_label", "api_access", "marketplace").
model PlanFeature {
  id      String @id @default(uuid()) @db.Uuid
  planId  String @map("plan_id") @db.Uuid
  feature String // slug da feature
  enabled Boolean @default(true)

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, feature])
  @@map("plan_features")
}

// ---- ASSINATURAS -----------------------------------------------------------

enum SubscriptionStatus {
  trial
  active
  past_due
  suspended
  cancelled
  expired
}

/// Assinatura de um tenant a um plano.
model Subscription {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @unique @map("tenant_id") @db.Uuid
  planId          String             @map("plan_id") @db.Uuid
  status          SubscriptionStatus @default(trial)
  trialEndsAt     DateTime?          @map("trial_ends_at")
  currentPeriodStart DateTime        @map("current_period_start")
  currentPeriodEnd   DateTime        @map("current_period_end")
  cancelAt        DateTime?          @map("cancel_at")
  cancelledAt     DateTime?          @map("cancelled_at")
  externalId      String?            @map("external_id")   // ID no Stripe/Asaas
  paymentProvider String?            @map("payment_provider") // 'stripe' | 'asaas' | 'manual'
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tenant  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan    Plan                  @relation(fields: [planId], references: [id])
  history SubscriptionHistory[]
  usage   SubscriptionUsage[]

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}

/// Histórico de mudanças de assinatura (upgrade/downgrade/cancel/reactivation).
model SubscriptionHistory {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  eventType      String   // 'created' | 'upgraded' | 'downgraded' | 'cancelled' | 'reactivated' | 'trial_end'
  fromPlanId     String?  @map("from_plan_id") @db.Uuid
  toPlanId       String?  @map("to_plan_id") @db.Uuid
  performedBy    String?  @map("performed_by") @db.Uuid // null = automático
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscription_history")
}

/// Uso atual do tenant por recurso (para enforcement de quotas).
model SubscriptionUsage {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  resource       String   // 'users' | 'products' | 'nfes_month' | 'ai_queries_month' etc.
  currentValue   Int      @default(0) @map("current_value")
  resetAt        DateTime? @map("reset_at") // para recursos com reset mensal
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, resource])
  @@map("subscription_usage")
}

// ---- COBRANÇA --------------------------------------------------------------

enum BillingProvider {
  stripe
  asaas
  mercadopago
  pagseguro
  manual
}

enum BillingStatus {
  pending
  paid
  failed
  refunded
  void
}

/// Registro de cobrança (fatura / pagamento).
model BillingRecord {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  subscriptionId  String?         @map("subscription_id") @db.Uuid
  provider        BillingProvider @default(manual)
  externalId      String?         @map("external_id") // ID na operadora
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("BRL")
  status          BillingStatus   @default(pending)
  description     String?
  invoiceUrl      String?         @map("invoice_url")
  paidAt          DateTime?       @map("paid_at")
  dueAt           DateTime?       @map("due_at")
  metadata        Json?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([provider, externalId])
  @@map("billing_records")
}

// ---- LICENCIAMENTO ---------------------------------------------------------

enum LicenseType {
  saas_subscription    // SaaS padrão (plano ativo)
  perpetual            // Licença perpétua (pago uma vez)
  trial                // Trial temporário
  nfr                  // Not For Resale
  developer            // Dev/test (sem suporte)
}

enum LicenseStatus {
  active
  expired
  revoked
  suspended
}

/// Licença associada a um tenant (Sprint 14 briefing: chave, ativação, expiração).
model License {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @unique @map("tenant_id") @db.Uuid
  type        LicenseType   @default(saas_subscription)
  status      LicenseStatus @default(active)
  features    String[]      // feature flags habilitadas
  maxUsers    Int?          @map("max_users")
  issuedAt    DateTime      @default(now()) @map("issued_at")
  expiresAt   DateTime?     @map("expires_at")
  revokedAt   DateTime?     @map("revoked_at")
  revokedBy   String?       @map("revoked_by") @db.Uuid
  metadata    Json?

  keys LicenseKey[]

  @@index([status])
  @@map("licenses")
}

/// Chave de ativação de licença (pode ser usada para ativação offline).
model LicenseKey {
  id          String    @id @default(uuid()) @db.Uuid
  licenseId   String    @map("license_id") @db.Uuid
  keyHash     String    @unique @map("key_hash") // SHA-256 da chave
  activatedAt DateTime? @map("activated_at")
  activatedIp String?   @map("activated_ip")
  hardwareId  String?   @map("hardware_id")  // fingerprint do servidor
  isRevoked   Boolean   @default(false) @map("is_revoked")
  createdAt   DateTime  @default(now()) @map("created_at")

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@map("license_keys")
}

