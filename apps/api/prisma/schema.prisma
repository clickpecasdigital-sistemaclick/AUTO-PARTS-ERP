  tenantId     String   @map("tenant_id") @db.Uuid
  reportId     String   @map("report_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  format       String   // 'pdf' | 'xlsx' | 'csv'
  status       String   @default("running") // 'running' | 'done' | 'error'
