// =============================================================================
// SEÇÃO 15 — HARDENING ENTERPRISE + SEGURANÇA + LGPD (Sprint 14)
// =============================================================================

// ---- SEGURANÇA: JWT + SESSÕES -----------------------------------------------

/// Tokens JWT revogados (logout, rotação de refresh, suspeita de comprometimento).
/// TTL mantido até a data de expiração natural do token — housekeeping
/// via job agendado que deleta registros com `expiresAt < now()`.
model JwtBlacklist {
  id        String   @id @default(uuid()) @db.Uuid
  jti       String   @unique // JWT ID (claim 'jti')
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  reason    String   @default("logout") // 'logout' | 'rotation' | 'revoked'
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([jti])
  @@index([expiresAt])
  @@map("jwt_blacklist")
}

/// Refresh Tokens com rotação obrigatória (briefing: Refresh Token Rotation).
/// A cada uso, o token atual é invalidado e um novo é gerado. Um token
/// reutilizado (reuse detection) desencadeia revogação de toda a família.
model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  tokenHash   String    @unique @map("token_hash") // SHA-256 do token
  userId      String    @map("user_id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  familyId    String    @map("family_id") @db.Uuid  // revogação em família
  deviceInfo  String?   @map("device_info")
  ipAddress   String?   @map("ip_address")
  isRevoked   Boolean   @default(false) @map("is_revoked")
  expiresAt   DateTime  @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tokenHash])
  @@index([userId, isRevoked])
  @@index([familyId])
  @@map("refresh_tokens")
}

/// 2FA — estrutura de autenticação de dois fatores (TOTP/Authenticator App).
/// `secret` armazenado criptografado (AES-256). Backup codes são hashed.
model TwoFactorAuth {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  isEnabled     Boolean   @default(false) @map("is_enabled")
  secret        String?   // TOTP secret criptografado AES-256
  backupCodes   String[]  @map("backup_codes") // hashed backup codes
  enabledAt     DateTime? @map("enabled_at")
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("two_factor_auth")
}

/// Histórico de senhas — impede reutilização das últimas N senhas
/// (padrão Enterprise: N = 10, configurável via `PasswordPolicy`).
model PasswordHistory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  passwordHash String   @map("password_hash") // bcrypt hash
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("password_history")
}

/// Tentativas de login — bloqueio por tentativas (briefing: Brute Force Protection).
/// Janela deslizante de 15 min — após 5 falhas consecutivas, conta bloqueada.
model LoginAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String   // e-mail ou username
  ipAddress  String   @map("ip_address")
  success    Boolean
  reason     String?  // motivo de falha
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([identifier, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

// ---- LGPD ------------------------------------------------------------------

enum LgpdConsentType {
  terms_of_use
  privacy_policy
  marketing
  data_processing
  third_party_sharing
}

enum LgpdRequestType {
  access
  export
  rectification
  erasure
  portability
  objection
}

enum LgpdRequestStatus {
  pending
  in_progress
  completed
  rejected
}

/// Consentimento LGPD por usuário (briefing: Consentimentos, Logs de Consentimento).
/// Cada alteração de consentimento gera um novo registro (imutável) —
/// histórico completo para auditoria.
model LgpdConsent {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  type        LgpdConsentType
  granted     Boolean
  version     String          // versão do documento de política aceito
  ipAddress   String?         @map("ip_address")
  userAgent   String?         @map("user_agent")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@index([tenantId, type])
  @@map("lgpd_consents")
}

/// Solicitação LGPD (direito de acesso, exportação, anonimização, esquecimento).
model LgpdRequest {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  type        LgpdRequestType
  status      LgpdRequestStatus @default(pending)
  description String?
  filePath    String?           @map("file_path") // para exportações
  processedAt DateTime?         @map("processed_at")
  processedBy String?           @map("processed_by") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@index([status])
  @@map("lgpd_requests")
}

// ---- BACKUP ---------------------------------------------------------------

enum BackupType {
  full
  incremental
  schema_only
}

enum BackupStatus {
  running
  completed
  failed
  validating
  restored
}

/// Registro de job de backup (briefing: automático, incremental, completo,
/// criptografado, versionado, compressão, validação automática).
model BackupJob {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String?      @map("tenant_id") @db.Uuid // null = sistema global
  type           BackupType
  status         BackupStatus @default(running)
  filePath       String?      @map("file_path")
  sizeBytes      BigInt?      @map("size_bytes")
  checksumSha256 String?      @map("checksum_sha256")
  isEncrypted    Boolean      @default(true) @map("is_encrypted")
  isCompressed   Boolean      @default(true) @map("is_compressed")
  error          String?
  startedAt      DateTime     @default(now()) @map("started_at")
  completedAt    DateTime?    @map("completed_at")
  expiresAt      DateTime?    @map("expires_at")

  @@index([type, status])
  @@index([startedAt])
  @@map("backup_jobs")
}

